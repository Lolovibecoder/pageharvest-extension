{
  "manifest_version": 3,
  "name": "PageHarvest-Text Extractor",
  "version": "1.0.0",
  "description": "Extract all visible text from any webpage and download it as a .txt file. Built for researchers, analysts, and power users.",
  "author": "0xodinx",

  "action": {
    "default_popup": "popup.html",
    "default_title": "PageHarvest-Text Extractor",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  }
}
